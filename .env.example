# Port to run the application on (cPanel usually sets this)
PORT=5000

# Session secret for Express session (REQUIRED - generate a random string)
SESSION_SECRET=change_this_to_a_random_string

# Admin password (set this on first deploy, then remove after first login)
ADMIN_PASSWORD=change_this_to_a_secure_password

# Set to "production" for cPanel
NODE_ENV=production
